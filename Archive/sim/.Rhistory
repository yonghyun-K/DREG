y_res = c(HT = y_HT, Diff = y_diff, GREG = y_GREG, KRR = y_kernel, RF = y_rf, NN = y_nn,
GREG_Sp = y_split, KRR_Sp = y_split_Kernel, RF_Sp = y_split_rf, NN_Sp = y_split_nn)
res = rbind(res, y_res)
sigma_res = c(HT = sigma_HT, Diff = sigma_diff, GREG = sigma_GREG, KRR = sigma_kernel, RF = sigma_rf, NN = sigma_nn,
GREG_Sp = sigma_split, KRR_Sp = sigma_Kernel, RF_Sp = sigma_rf, NN_Sp = sigma_nn)
res2 = rbind(res2, sigma_res)
res3 = rbind(res3, ifelse(abs(y_res - t_y) > 1.96 * sigma_res, 0, 1))
}
BIAS = colMeans(res - t_y)
SE = apply(res, 2, function(x) sqrt(var(x) * (length(x)-1)/length(x) ))
RMSE = apply(res - t_y, 2, function(x) sqrt(mean(x^2)))
# colMeans(res)
round(cbind(BIAS = BIAS, SE = SE, RMSE = RMSE), 3)
#Point estimation
round(cbind(SB = BIAS / SE , RE = RMSE / RMSE[3]), 3)
#cbind(BIAS, SE, RMSE)
#xtable::xtable(cbind(BIAS, SE, RMSE), caption = "Informative Sampmling")
BIAS2 = colMeans(res2 - rep(SE, each = nrow(res2)))
SE2 = apply(res2, 2, function(x) sqrt(var(x) * (length(x)-1)/length(x) ))
RMSE2 = apply(res2 - rep(SE, each = nrow(res2)), 2, function(x) sqrt(mean(x^2)))
#Variance estimation
round(cbind(RB = BIAS2 / SE, CR = colMeans(res3)), 3)
library(ggplot2)
ggplot() +
geom_density(data = data.frame(res), aes(x = Diff, fill = "Diff"), alpha = 0.3) +
geom_density(data = data.frame(res), aes(x = GREG, fill = "GREG"), alpha = 0.3) +
geom_density(data = data.frame(res), aes(x = GREG_Sp, fill = "GREG_Sp"), alpha = 0.3) +
geom_vline(xintercept = t_y, col = "red")
args <- c(1,1,500)
N = 2000
n = 100
m = 50
p = 4
g = N
model = args[1]
print("model = ")
print(args[1])
smpl = args[2]
print("smpl = ")
print(args[2])
set.seed(2)
# X = matrix(rnorm(N * p, 2, 1), nr = N, nc = p)
if(smpl == 1 | smpl == 3){
Stratified = F
}else if(smpl == 2 | smpl == 4){
Stratified = T
}
library(mvtnorm)
library(glmnet)
library(nnet)
library(randomForest)
kernel = "polydot"
# X = pnorm(X)
X = matrix(rnorm(N * p, 2, 1), nr = N, nc = p)
# X = scale(X, T, T)
if(model == 1){
muX = rowSums(X) # m1
}else if(model == 2){
muX = rowSums(exp(X)) #m2
}else if(model == 3){
muX = exp(-X[,1]) + X[,3] #m3
}else if(model == 4){
muX = sign(X[,1] - X[,2]) * sin(X[,3]) * exp(X[,4]) #m4
}
e = rnorm(N, 0, sd(muX) / sqrt(5))
e_rel = e + rnorm(N, 0, sd(muX) / sqrt(10))
y = muX + e
t_y = sum(y)
plot(y ~ muX)
# pi1 = e^2 / sum(e^2) * n
library(CVST)
# library(mgcv)
# krr <- constructKRRLearner()
#
# dat <- constructData(X,y)
# X2 <- matrix(rnorm(N * p, 2, 1), nr = N, nc = p)
# dat_tst <- constructData(X2 ,0)
#
# par(mfrow=c(3,3),oma = c(5,4,0,0) + 0.1,mar = c(0,0,1,1) + 0.1)
# lambdas= 10^(-8:0)
#
# for(lambda in lambdas){
#   # param <- list(kernel="rbfdot", sigma=0.0005, lambda=lambda)
#   param <- list(kernel="polydot", lambda=lambda, degree = 2, scale = 1, offset = 1)
#   # param <- list(kernel="vanilladot", lambda=lambda)
