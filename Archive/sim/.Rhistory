#
#   # if(length(Index_sub1) != 0){
#   y_s1 = y[Index_sub1]
#   X_s1 = X[Index_sub1, ,drop = F]
#   d1_s1 = d1[Index_sub1]
#
#   y_s2 = y[Index_sub2]
#   X_s2 = X[Index_sub2, ,drop = F]
#   d1_s2 = d1[Index_sub2]
#   lm_obj2 = lm(y_s2 ~ 0 +  X_s2, weights = d1_s2)
