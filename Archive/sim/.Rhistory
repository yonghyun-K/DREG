#   lines(as.vector(X2^2 %*% beta)[Index],pred[Index],col='blue')
# }
if(smpl == 2){
r = 0 # S2
}else if(smpl == 4){
r = 1 # S4
}
#
if(Stratified == TRUE){
if(r == 0){
z = rnorm(n = N, 0, 1)
}else{
ratio = (1 - r) / r
z = rnorm(n = N, 0, sqrt(ratio)) - e
}
# z = -e
# z = rnorm(n = N, 0, 1)
z_sorted_idx = order(z)
len = round(N / 4)
}
if(Stratified == FALSE){
# pi1 = runif(N, min = 0.2, max = 0.8)
# pi1 = (e - min(e)) / (max(e) - min(e)) / 2 + 0.10
if(smpl == 1){
pi1 = rep(n / N, N)     # S1
}else if(smpl == 3){
pi1 = (e_rel - min(e_rel)) / (max(e_rel) - min(e_rel)) / 2 + 0.10     # S3
}
pi1 = pi1 / sum(pi1) * n
d1 = 1 / pi1
}
res = NULL
res2 = NULL
res3 = NULL
SIMNUM = args[3]
print("SIMNUM = ")
print(SIMNUM)
X = cbind(1, X)
for(simnum in 1:SIMNUM){
print(simnum)
# set.seed(simnum)
if(Stratified == TRUE){
Index = rep(0, n)
d1 = rep(0, N)
n_h = c(10, 20, 30, 40) / 100 * n
# n_h = c(25, 25, 25, 25) / 100 * n
cumn_h = cumsum(n_h)
Omega = matrix(0, nr = n, nc = n)
for (i in 1:4){
Idx_z = (len * (i - 1)+ 1): (len * i)
Idx = z_sorted_idx[Idx_z]
d1[Idx] = len / n_h[i]
from = ifelse(i == 1, 0, cumn_h[i-1])
Index[(from + 1) : cumn_h[i]] = sample(Idx, size = n_h[i], replace = FALSE)
# len^2 / n_h[i]^2 - len * (len - 1) / n_h[i] / (n_h[i] - 1)
# (1 - n_h[i] / (n_h[i]-1) * (len-1) / len)* len^2 / n_h[i]^2
Omega_tmp = matrix(len^2 / n_h[i]^2 - len * (len - 1) / n_h[i] / (n_h[i] - 1) , nr = n_h[i], nc = n_h[i])
diag(Omega_tmp) = (1 - n_h[i] / len)  * len^2 / n_h[i]^2
Omega[(from + 1) : cumn_h[i], (from + 1) : cumn_h[i]] = Omega_tmp
}
}
if(simnum == 1) plot(1 / d1, e, xlab = "Inclusion Probability", ylab = "error")
if(Stratified == FALSE){
Index = sample(1:N, size = n, replace = FALSE, prob = pi1)
Omega = matrix(0, nr = n, nc = n)
diag(Omega) = (1 - pi1[Index]) / pi1[Index]^2
}
y_s = y[Index]
X_s = X[Index, ,drop = F]
d1_s = d1[Index]
lm_obj = lm(y_s ~  0 + X_s, weights = d1_s)
beta_hat = lm_obj$coefficients
#drop(solve(t(X_s) %*% diag(d1_s) %*% X_s, t(X_s) %*% diag(d1_s) %*% y_s))
# beta_hat = unname(lm(y_s ~  t(apply(X_s, 1, function(k) k
# - colSums(X_s * d1_s) / N)), weights = d1_s)$coefficients[-1])
y_HT = sum(y_s * d1_s)
sigma_HT = sqrt(drop(t(y_s)  %*% Omega %*% y_s))
# sum(sapply(1:n, function(k) sapply(1:n, function(l)
#   ifelse(k == l, 1 - n / N, 1 - n / (n - 1) * (N - 1) / N) * e_s[k] * e_s[l] * N / n * N / n  ))) / N^2
e_s = e[Index]
# print(sum(e_s * d1_s))
y_diff = drop(sum(muX) + sum(e_s * d1_s))
sigma_diff = sqrt(drop(t(e_s)  %*% Omega %*% e_s))
y_GREG = drop(colSums(X) %*% beta_hat + sum((y_s - drop(X_s %*% beta_hat)) * d1_s))
e_s = y_s - X_s %*% beta_hat
sigma_GREG = sqrt(drop(t(e_s)  %*% Omega %*% e_s))
SRB_res = NULL
for(k in 1:10){
# set.seed(k)
if(Stratified == TRUE){
Index1 = NULL
for(j in 1:length(n_h)){
if(j == 1){
Index1 = c(Index1, sample(1:cumn_h[j], n_h[j] / 2))
}else{
Index1 = c(Index1, sample(cumn_h[j-1]:cumn_h[j], n_h[j] / 2))
}
}
Index2 = (1:n)[!(1:n %in% Index1)]
y_s1 = y_s[Index1]
X_s1 = X_s[Index1, ,drop = F]
d1_s1 = d1_s[Index1]
lm_obj1 = lm(y_s1 ~  0 +X_s1, weights = d1_s1)
beta_hat1 = lm_obj1$coefficients
residu = 0
for(j in 1:length(n_h)){
residu = residu + (len - n_h[j] / 2) / (n_h[j] / 2) *
sum(y_s[Index2] - drop(X_s[Index2, ,drop = F] %*% beta_hat1))
}
SRB_res = c(SRB_res,
drop(colSums(X) %*% beta_hat1 + sum((y_s - drop(X_s %*% beta_hat1)) * d1_s)) + residu)
}
}
y_SRB = mean(SRB_res)
sigma_SRB = sigma_GREG
# lm_obj = lm(y_s ~  0 + X_s, weights = d1_s - 1)
# beta_hat = lm_obj$coefficients
# y_Peff = drop(colSums(X) %*% beta_hat + sum((y_s - drop(X_s %*% beta_hat)) * d1_s))
if(simnum == 1){
test <- gausspr(X_s, y_s, kernel = kernel, scaled = F, kpar = list(degree = 2))
kpar <- test@kernelf@kpar
}else{
test <- gausspr(X_s, y_s, kernel = kernel, scaled = F, kpar = kpar)
}
# if(simnum == 1){
#   test <- gausspr(X_s, y_s, kernel = "polydot", scaled = F, kpar = list(degree = 2))
#   kpar <- test@kernelf@kpar
# }else{
#   test <- gausspr(X_s, y_s, kernel = "polydot", scaled = F, kpar = kpar)
# }
# test <- gausspr(X_s, y_s, kernel = "splinedot", scaled = F)
m_X <- predict(test,X)
m_X_s <- predict(test,X_s)
y_kernel = sum(m_X) + sum((y_s - m_X_s) * d1_s)
e_s = y_s - m_X_s
sigma_kernel = sqrt(drop(t(e_s)  %*% Omega %*% e_s))
# plot(m_X, y)
# plot(m_X_s, y_s)
tmp_res1 = NULL
tmp_res2 = NULL
for(k_val in 1:10){
nn <- nnet(x = X_s, y = y_s, size = 5, linout=T, trace = FALSE)
tmp_res1[[k_val]] <- nn
tmp_res2 <- c(tmp_res2, nn$value)
}
nn <- tmp_res1[[which.min(tmp_res2)]]
m_X <- predict(nn,X)
m_X_s <- predict(nn,X_s)
y_nn = sum(m_X) + sum((y_s - m_X_s) * d1_s)
e_s = y_s - m_X_s
sigma_nn = sqrt(drop(t(e_s)  %*% Omega %*% e_s))
data = data.frame(cbind(y_s, X_s))
rf <- randomForest(y_s ~ ., data = data)
colnames(X) <- names(data)[-1]
colnames(X_s) <- names(data)[-1]
m_X <- predict(rf,X)
m_X_s <- predict(rf,X_s)
y_rf = sum(m_X) + sum((y_s - m_X_s) * d1_s)
e_s = y_s - m_X_s
sigma_rf = sqrt(drop(t(e_s)  %*% Omega %*% e_s))
# y_model = drop(colSums(X) %*% beta_hat)
# tmp <- sample(factor(rep(1:g, length.out=N),
#                      labels=paste0(1:g)))
# split_group = by(1:N, tmp, c)
