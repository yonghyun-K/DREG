#
#   y_proposed = y_proposed + drop(colSums(X[SubIndex, , drop = F]) %*% beta_hat2  +
#                                    sum((y_s1 - drop(X_s1 %*% beta_hat2)) * d1_s1))
# }
y_split_vec = NULL
y_split_Kernel_vec = NULL
y_split_nn_vec = NULL
y_split_rf_vec = NULL
e_s_vec = NULL
e_s_Kernel_vec = NULL
e_s_nn_vec = NULL
e_s_rf_vec = NULL
for(k in 1:10){
set.seed(k)
SubIndex = sample(1:N, size = round(N / 2), replace = FALSE)
Index_sub1 = Index[Index %in% SubIndex]
Index_sub2 = Index[!(Index %in% SubIndex)]
# Index_sub1 = Index[sample(1:n, size = m, replace = FALSE)]
# Index_sub2 = Index[!(Index %in% Index_sub1)]
y_s1 = y[Index_sub1]
X_s1 = X[Index_sub1, ,drop = F]
d1_s1 = d1[Index_sub1]
lm_obj1 = lm(y_s1 ~  0 +X_s1, weights = d1_s1)
beta_hat1 = lm_obj1$coefficients
y_s2 = y[Index_sub2]
X_s2 = X[Index_sub2, ,drop = F]
d1_s2 = d1[Index_sub2]
lm_obj2 = lm(y_s2 ~ 0 +  X_s2, weights = d1_s2)
beta_hat2 = lm_obj2$coefficients
# y_split = drop(colSums(X) %*% beta_hat + sum((y_s1 - drop(X_s1 %*% beta_hat2)) * d1_s1)
# + sum((y_s2 - drop(X_s2 %*% beta_hat1)) * d1_s2))
# y_split = drop(colSums(X) %*% (sum(d1_s2) / sum(d1_s) * beta_hat1 + sum(d1_s1) / sum(d1_s) * beta_hat2) +
#                     sum((y_s1 - drop(X_s1 %*% beta_hat2)) * d1_s1) + sum((y_s2 - drop(X_s2 %*% beta_hat1)) * d1_s2))
t1_hat = colSums(X[SubIndex, ]) %*% beta_hat2 + sum((y_s1 - drop(X_s1 %*% beta_hat2)) * d1_s1)
y_split = drop(colSums(X[SubIndex, ]) %*% beta_hat2 + colSums(X[-SubIndex, ]) %*% beta_hat1 +
sum((y_s1 - drop(X_s1 %*% beta_hat2)) * d1_s1) + sum((y_s2 - drop(X_s2 %*% beta_hat1)) * d1_s2))
# y_split = drop(colSums(X[SubIndex, ]) %*% beta_hat2 +
#                     sum((y_s1 - drop(X_s1 %*% beta_hat2)) * d1_s1))*2
e_s_tmp = ifelse(Index %in% Index_sub1, y_s - X_s %*% beta_hat2, y_s - X_s %*% beta_hat1)
e_s_vec = rbind(e_s_vec, e_s_tmp)
if(is.na(y_split)) stop()
y_split_vec = c(y_split_vec, y_split)
if(simnum == 1){
test1 <- gausspr(X_s1, y_s1, kernel = kernel, scaled = F, kpar = list(degree = 2))
kpar1 <- test1@kernelf@kpar
}else{
test1 <- gausspr(X_s1, y_s1, kernel = kernel, scaled = F, kpar = kpar1)
}
m_X2 <- predict(test1,X[-SubIndex, ])
m_X_s2 <- predict(test1,X_s2)
if(simnum == 1){
test2 <- gausspr(X_s2, y_s2, kernel = kernel, scaled = F, kpar = list(degree = 2))
kpar2 <- test2@kernelf@kpar
}else{
test2 <- gausspr(X_s2, y_s2, kernel = kernel, scaled = F, kpar = kpar2)
}
m_X1 <- predict(test2,X[SubIndex, ])
m_X_s1 <- predict(test2,X_s1)
y_split_Kernel = sum(m_X2) + sum((y_s2 - m_X_s2) * d1_s2) + sum(m_X1) + sum((y_s1 - m_X_s1) * d1_s1)
y_split_Kernel_vec = c(y_split_Kernel_vec, y_split_Kernel)
e_s_Kernel = rep(0, n)
e_s_Kernel[Index %in% Index_sub1] = y_s1 - c(m_X_s1)
e_s_Kernel[Index %in% Index_sub2] = y_s2 - c(m_X_s2)
e_s_Kernel_vec = rbind(e_s_Kernel_vec, e_s_Kernel)
# Neural Net ####
tmp_res1 = NULL
tmp_res2 = NULL
for(k_val in 1:10){
nn <- nnet(x = X_s1, y = y_s1, size = 5, linout=T, trace = FALSE)
tmp_res1[[k_val]] <- nn
tmp_res2 <- c(tmp_res2, nn$value)
}
nn <- tmp_res1[[which.min(tmp_res2)]]
m_X2 <- predict(nn,X[-SubIndex, ])
m_X_s2 <- predict(nn,X_s2)
tmp_res1 = NULL
tmp_res2 = NULL
for(k_val in 1:10){
nn <- nnet(x = X_s2, y = y_s2, size = 5, linout=T, trace = FALSE)
tmp_res1[[k_val]] <- nn
tmp_res2 <- c(tmp_res2, nn$value)
}
nn <- tmp_res1[[which.min(tmp_res2)]]
m_X1 <- predict(nn,X[SubIndex, ])
m_X_s1 <- predict(nn,X_s1)
y_split_nn = sum(m_X2) + sum((y_s2 - m_X_s2) * d1_s2) + sum(m_X1) + sum((y_s1 - m_X_s1) * d1_s1)
y_split_nn_vec = c(y_split_nn_vec, y_split_nn)
e_s_nn = rep(0, n)
e_s_nn[Index %in% Index_sub1] = y_s1 - c(m_X_s1)
e_s_nn[Index %in% Index_sub2] = y_s2 - c(m_X_s2)
e_s_nn_vec = rbind(e_s_nn_vec, e_s_nn)
# Random Forest ####
colnames(X) <- names(data)[-1]
colnames(X_s1) <- names(data)[-1]
colnames(X_s2) <- names(data)[-1]
data = data.frame(cbind(y_s1, X_s1))
rf <- randomForest(y_s1 ~ ., data = data)
m_X2 <- predict(rf,X[-SubIndex, ])
m_X_s2 <- predict(rf,X_s2)
data = data.frame(cbind(y_s2, X_s2))
rf <- randomForest(y_s2 ~ ., data = data)
m_X1 <- predict(rf,X[SubIndex, ])
m_X_s1 <- predict(rf,X_s1)
y_split_rf = sum(m_X2) + sum((y_s2 - m_X_s2) * d1_s2) + sum(m_X1) + sum((y_s1 - m_X_s1) * d1_s1)
y_split_rf_vec = c(y_split_nn_vec, y_split_nn)
e_s_rf = rep(0, n)
e_s_rf[Index %in% Index_sub1] = y_s1 - c(m_X_s1)
e_s_rf[Index %in% Index_sub2] = y_s2 - c(m_X_s2)
e_s_rf_vec = rbind(e_s_rf_vec, e_s_rf)
}
e_s_tmp = colMeans(e_s_vec)
e_s_Kernel = colMeans(e_s_Kernel_vec)
e_s_nn = colMeans(e_s_nn_vec)
e_s_rf = colMeans(e_s_rf_vec)
y_split = mean(y_split_vec)
sigma_split = sqrt(drop(t(e_s_tmp)  %*% Omega %*% e_s_tmp))
y_split_Kernel = mean(y_split_Kernel_vec)
sigma_Kernel = sqrt(drop(t(e_s_Kernel)  %*% Omega %*% e_s_Kernel))
y_split_nn = mean(y_split_nn_vec)
sigma_nn = sqrt(drop(t(e_s_nn)  %*% Omega %*% e_s_nn))
y_split_rf = mean(y_split_rf_vec)
sigma_rf = sqrt(drop(t(e_s_rf)  %*% Omega %*% e_s_rf))
# y_unbiased = drop(colSums(X) %*% beta_hat1 + sum((y_s1 - drop(X_s1 %*% beta_hat1)))
#                   + sum((y_s2 - drop(X_s2 %*% beta_hat1)) * 2))
y_res = c(HT = y_HT, Diff = y_diff, GREG = y_GREG, SRB = y_SRB, KRR = y_kernel, RF = y_rf, NN = y_nn,
GREG_Sp = y_split, KRR_Sp = y_split_Kernel, RF_Sp = y_split_rf, NN_Sp = y_split_nn)
res = rbind(res, y_res)
sigma_res = c(HT = sigma_HT, Diff = sigma_diff, GREG = sigma_GREG, SRB = sigma_SRB, KRR = sigma_kernel, RF = sigma_rf, NN = sigma_nn,
GREG_Sp = sigma_split, KRR_Sp = sigma_Kernel, RF_Sp = sigma_rf, NN_Sp = sigma_nn)
res2 = rbind(res2, sigma_res)
res3 = rbind(res3, ifelse(abs(y_res - t_y) > 1.96 * sigma_res, 0, 1))
}
BIAS = colMeans(res - t_y)
SE = apply(res, 2, function(x) sqrt(var(x) * (length(x)-1)/length(x) ))
RMSE = apply(res - t_y, 2, function(x) sqrt(mean(x^2)))
# colMeans(res)
#Point estimation
tmp_tbl <- round(cbind(SB = BIAS / RMSE, RE = RMSE / RMSE[3]), 3)
tmp_tbl
xtable::xtable(tmp_tbl, digits = 3)
#cbind(BIAS, SE, RMSE)
#xtable::xtable(cbind(BIAS, SE, RMSE), caption = "Informative Sampmling")
BIAS2 = colMeans(res2 - rep(SE, each = nrow(res2)))
SE2 = apply(res2, 2, function(x) sqrt(var(x) * (length(x)-1)/length(x) ))
RMSE2 = apply(res2 - rep(SE, each = nrow(res2)), 2, function(x) sqrt(mean(x^2)))
#Variance estimation
round(cbind(RB = BIAS2 / SE, CR = colMeans(res3)), 3)
library(ggplot2)
ggplot() +
geom_density(data = data.frame(res), aes(x = Diff, fill = "Diff"), alpha = 0.3) +
geom_density(data = data.frame(res), aes(x = GREG, fill = "GREG"), alpha = 0.3) +
geom_density(data = data.frame(res), aes(x = GREG_Sp, fill = "GREG_Sp"), alpha = 0.3) +
geom_vline(xintercept = t_y, col = "red")
